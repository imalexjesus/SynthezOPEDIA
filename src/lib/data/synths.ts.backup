// Группировка по сериям для отображения в каталоге
export const groupedSynths = synths.reduce((acc, synth) => {
  const key = `${synth.brand} - ${synth.series}`;
  if (!acc[key]) acc[key] = [];
  acc[key].push(synth);
  return acc;
}, {} as Record<string, SynthModel[]>);

// Список уникальных брендов
export const brands = [...new Set(synths.map(s => s.brand))];

// Список уникальных серий
export const series = [...new Set(synths.map(s => s.series))];

// Количество моделей
export const totalModels = synths.length;

// Количество гемов
export const totalGems = synths.filter(s => s.isGem).length;