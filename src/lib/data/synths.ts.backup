export interface SynthModel {
  id: string;               // уникальный ID (например "yamaha-pss-470")
  brand: 'Yamaha' | 'Casio' | 'Bontempi' | 'Other';
  series: string;           // например "PSS (PortaSound)", "VL-Tone"
  modelName: string;        // например "PSS-470"
  year: number;             // год выпуска
  formFactor: 'micro' | 'mini' | 'compact' | 'full';
  keysCount: number;        // количество клавиш
  synthEngine: string;      // FM, PCM, аналоговый орган, семплер и т.д.
  dimensions?: string;      // габариты (если известны)
  description: string;      // краткое описание на русском
  isGem: boolean;           // "гем коллекции"
  images: string[];         // массив URL изображений (3‑5 фото)
  // Дополнительные поля (по возможности)
  polyphony?: number;
  midi?: boolean;
  sequencer?: boolean;
  autoAccompaniment?: boolean;
  power?: string;           // батарейки/адаптер
}

